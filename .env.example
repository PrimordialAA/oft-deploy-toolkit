# ============================================================
#  OFT Deployment — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# The orchestrator auto-fills "Set after deployment" vars during deploy.
# You only need to fill in the sections above those markers.

# ============ TOKEN CONFIGURATION (REQUIRED) ============
TOKEN_NAME=
TOKEN_SYMBOL=
# Optional: TON Jetton metadata URI (JSON with name/symbol/image)
# TOKEN_METADATA_URI=https://example.com/metadata/mytoken.json

# ============ AUTHENTICATION ============
# EVM: Use either MNEMONIC or PRIVATE_KEY (not both)
MNEMONIC=
PRIVATE_KEY=

# ============ EVM (ARBITRUM) ============
RPC_URL_ARBITRUM=https://arb1.arbitrum.io/rpc
EVM_DEPLOYER_ADDRESS=
# Set after deployment:
ARBITRUM_CONTRACT_ADDRESS=

# ============ BLOCK EXPLORER API KEYS ============
ARBISCAN_API_KEY=

# ============ SOLANA ============
SOLANA_PRIVATE_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_DEPLOYER_ADDRESS=
# Directories containing solana, anchor, cargo-build-sbf binaries.
# Use full paths (not ~). The orchestrator auto-expands ~ but explicit paths are safer.
# Example: EXTRA_PATH=/home/you/.cargo/bin:/home/you/.local/share/solana/install/active_release/bin:/home/you/.avm/bin
EXTRA_PATH=
# Set after deployment:
SOLANA_OFT_PROGRAM_ID=
SOLANA_OFT_STORE=

# ============ STARKNET ============
STARKNET_PRIVATE_KEY=
STARKNET_ACCOUNT_ADDRESS=
# Either var name works:
STARKNET_RPC_URL=https://starknet-mainnet.public.blastapi.io/rpc/v0_7
# RPC_STARKNET=
# Optional: override LayerZero class hashes (defaults work for standard OFT)
# STARKNET_ACCOUNT_CLASS_HASH=
# STARKNET_OFT_ERC20_CLASS_HASH=
# STARKNET_OFT_ADAPTER_CLASS_HASH=
# Set after deployment:
STARKNET_ERC20_ADDRESS=
STARKNET_ADAPTER_ADDRESS=

# ============ SUI ============
SUI_PRIVATE_KEY=
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
SUI_DEPLOYER_ADDRESS=
# Set after deployment (auto-detected by orchestrator):
SUI_TOKEN_PACKAGE=
SUI_TREASURY_CAP=
SUI_COIN_METADATA=
SUI_COIN_TYPE=
SUI_OFT_PACKAGE=
SUI_OFT_OBJECT=
SUI_OAPP_OBJECT=
SUI_ADMIN_CAP=
SUI_INIT_TICKET=

# ============ TON ============
TON_MNEMONIC=
TON_RPC_URL=https://toncenter.com/api/v2/jsonRPC
TON_API_KEY=
TON_DEPLOYER_ADDRESS=
# Set after deployment:
TON_OFT_ADAPTER=
TON_OFT_ADAPTER_HASH=
TON_JETTON_MASTER=
